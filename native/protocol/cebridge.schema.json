{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cedroid.dev/schemas/cebridge-v0.json",
  "title": "CEBridge protocol sketch",
  "description": "Planning schema only; this is not a frozen wire ABI.",
  "type": "object",
  "required": ["protocol", "major", "minor", "services"],
  "properties": {
    "protocol": { "const": "CEBRIDGE" },
    "major": { "type": "integer", "const": 0 },
    "minor": { "type": "integer", "minimum": 1 },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "name": { "type": "string", "minLength": 1 },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
